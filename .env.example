# ── Data ──────────────────────────────────────────────
DATA_DIR=data/
OUTPUT_DIR=outputs/

# ── Device ────────────────────────────────────────────
DEVICE=cuda          # cuda | cpu
NUM_WORKERS=4

# ── Training Hyperparameters ──────────────────────────
LEARNING_RATE=1e-4
BATCH_SIZE=32
EPOCHS=100
SEED=42

# ── Logging ───────────────────────────────────────────
LOG_DIR=logs/
LOG_LEVEL=INFO       # DEBUG | INFO | WARNING | ERROR
